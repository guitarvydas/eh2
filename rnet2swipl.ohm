rnet2swipl {
  Top = "group" "{" Diagram+ "}"
  Diagram = "diagram" "{" Cellid "[" Cell+ "]" "}"
  Cell = 
   | "gate" "{" Cellid Attr+ "}" -- gate
   | "rect" "{" Cellid Attr+ "}" -- rect
   | "edge" "{" Cellid Attr+ "}" -- edge
  Cellid= "id" "=" str
  Attr = name "=" str
  str = "\"" (~"\"" any)* "\""
  name = letter alnum*
}
